{
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://www.nexxtechs.com/$1",
      "statusCode": 301,
      "has": [
        {
          "type": "host",
          "value": "nexxtechs.com"
        }
      ]
    }
  ],
  "routes": [
    { "src": "^/api/(.*)", "dest": "https://nexxtech-oi8e.vercel.app/api/$1" },
    { "handle": "filesystem" },
    { "src": "^/.*", "dest": "/index_fallback.html" }
  ]
}
